    "import pandas as pd\n",
    "s1 = pd.Series({1: 'Alice', 2: 'Jack', 3: 'Molly'})\n",
    "s2 = pd.Series({'Alice': 1, 'Jack': 2, 'Molly': 3})\n",
    "df = pd.DataFrame(s1,s2).reset_index()\n",
    "df = df.where(df['index']>=2)\n",
